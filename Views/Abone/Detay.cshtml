@model KcetasWeb.ViewModels.AboneDetayViewModel
@{
    ViewData["Title"] = "Abone Detayı - " + Model.Abone.abone_no;
}

<div class="mb-4 mt-3 d-flex justify-content-between align-items-center">
    <a href="/Abone/Index" class="btn btn-sm btn-outline-secondary fw-bold shadow-sm">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
    <div>
        <a href="/Abone/Duzenle/@Model.Abone.abone_id" class="btn btn-warning btn-sm fw-bold shadow-sm me-2"><i class="bi bi-pencil"></i> Düzenle</a>
        <form action="/Abone/Sil/@Model.Abone.abone_id" method="post" class="d-inline" onsubmit="return confirm('Bu aboneyi silmek istediğinize emin misiniz?');">
            <button type="submit" class="btn btn-danger btn-sm fw-bold shadow-sm"><i class="bi bi-trash"></i> Sil</button>
        </form>
    </div>
</div>

<!-- Profil Kartı -->
<div class="card shadow-sm border-0 rounded-4 mb-4 bg-white">
    <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-4" style="width: 80px; height: 80px;">
                    @if (Model.Abone.abone_tipi == KcetasWeb.Models.Enums.AboneTipi.Bireysel) {
                        <i class="bi bi-person-fill fs-1"></i>
                    } else {
                        <i class="bi bi-buildings-fill fs-1"></i>
                    }
                </div>
                <div>
                    <h3 class="fw-bold text-dark mb-1">
                        @(Model.Abone.abone_tipi == KcetasWeb.Models.Enums.AboneTipi.Bireysel ? $"{Model.Abone.Ad} {Model.Abone.Soyad}" : Model.Abone.Unvan)
                    </h3>
                    <p class="text-muted mb-2 fs-5">@Model.Abone.abone_no</p>
                    <div class="d-flex gap-2">
                        <span class="badge bg-light text-dark border font-monospace">@Model.KimlikNoMaskeli</span>
                        <span class="badge bg-@(Model.Abone.abone_tipi == KcetasWeb.Models.Enums.AboneTipi.Bireysel ? "info" : "warning") bg-opacity-10 text-@(Model.Abone.abone_tipi == KcetasWeb.Models.Enums.AboneTipi.Bireysel ? "info" : "warning") border">@Model.Abone.abone_tipi</span>
                        <span class="badge bg-@(Model.Abone.Durum == "Aktif" ? "success" : "secondary")">@Model.Abone.Durum</span>
                    </div>
                </div>
            </div>
            <div class="text-end">
                <div class="mb-2">
                    <i class="bi bi-telephone-fill text-muted me-2"></i> <span class="fw-semibold">@Model.Abone.telefon</span>
                </div>
                <div>
                    <i class="bi bi-envelope-fill text-muted me-2"></i> <span class="fw-semibold">@Model.Abone.e_posta</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="card shadow-sm border-0 rounded-4 mb-5">
    <div class="card-header bg-white border-bottom-0 pt-3 px-4 pb-0">
        <ul class="nav nav-tabs border-bottom-0" id="aboneTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold text-primary" id="genel-tab" data-bs-toggle="tab" data-bs-target="#genel" type="button" role="tab">
                    <i class="bi bi-info-circle me-1"></i> Genel Bilgi
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="sozlesme-tab" data-bs-toggle="tab" data-bs-target="#sozlesme" type="button" role="tab">
                    <i class="bi bi-file-earmark-text me-1"></i> Sözleşmeler
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="nokta-tab" data-bs-toggle="tab" data-bs-target="#nokta" type="button" role="tab">
                    <i class="bi bi-geo-alt me-1"></i> Tüketim Noktaları
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="fatura-tab" data-bs-toggle="tab" data-bs-target="#fatura" type="button" role="tab">
                    <i class="bi bi-receipt me-1"></i> Faturalar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="isemri-tab" data-bs-toggle="tab" data-bs-target="#isemri" type="button" role="tab">
                    <i class="bi bi-tools me-1"></i> İş Emirleri
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-dark" id="bildirim-tab" data-bs-toggle="tab" data-bs-target="#bildirim" type="button" role="tab">
                    <i class="bi bi-bell me-1"></i> Bildirimler
                </button>
            </li>
        </ul>
    </div>
    
    <div class="card-body p-4 bg-light rounded-bottom-4">
        <div class="tab-content" id="aboneTabsContent">
            
            <!-- Genel Bilgi Tab -->
            <div class="tab-pane fade show active" id="genel" role="tabpanel">
                <h5 class="fw-bold mb-4">Abonelik Detayları</h5>
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="bg-white p-3 rounded-3 border shadow-sm h-100">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">İletişim Bilgileri</h6>
                            <p class="mb-2"><span class="text-muted">Telefon:</span> <span class="fw-semibold float-end">@Model.Abone.telefon</span></p>
                            <p class="mb-2"><span class="text-muted">E-Posta:</span> <span class="fw-semibold float-end">@Model.Abone.e_posta</span></p>
                            <p class="mb-0"><span class="text-muted">Kayıt Tarihi:</span> <span class="fw-semibold float-end">@Model.Abone.CreatedAt.ToString("dd.MM.yyyy")</span></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="bg-white p-3 rounded-3 border shadow-sm h-100">
                            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3">Resmi Bilgiler</h6>
                            <p class="mb-2"><span class="text-muted">Müşteri Tipi:</span> <span class="fw-semibold float-end">@Model.Abone.abone_tipi</span></p>
                            <p class="mb-2"><span class="text-muted">Kimlik/Vergi No:</span> <span class="fw-semibold float-end">@Model.KimlikNoMaskeli</span></p>

                        </div>
                    </div>
                </div>
            </div>

            <!-- Sözleşmeler Tab -->
            <div class="tab-pane fade" id="sozlesme" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Aktif Sözleşmeler</h5>
                    <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> Yeni Sözleşme</button>
                </div>
                <div class="text-center py-5 bg-white rounded-3 border border-dashed">
                    <i class="bi bi-file-earmark-text text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="fw-bold text-secondary">Sözleşme Kaydı Bulunamadı</h6>
                    <p class="text-muted small">Bu aboneye ait sistemde henüz bir perakende satış sözleşmesi oluşturulmamış.</p>
                </div>
            </div>

            <!-- Tüketim Noktaları Tab -->
            <div class="tab-pane fade" id="nokta" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Bağlı Tüketim Noktaları (Tesisatlar)</h5>
                    <button class="btn btn-sm btn-outline-primary"><i class="bi bi-link"></i> Nokta Bağla</button>
                </div>
                <div class="text-center py-5 bg-white rounded-3 border border-dashed">
                    <i class="bi bi-geo-alt text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="fw-bold text-secondary">Tüketim Noktası Bulunamadı</h6>
                    <p class="text-muted small">Bu abonenin üzerine kayıtlı aktif bir tüketim noktası bulunmuyor.</p>
                </div>
            </div>

            <!-- Faturalar Tab -->
            <div class="tab-pane fade" id="fatura" role="tabpanel">
                <h5 class="fw-bold mb-4">Fatura Geçmişi</h5>
                <div class="text-center py-5 bg-white rounded-3 border border-dashed">
                    <i class="bi bi-receipt text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="fw-bold text-secondary">Fatura Kaydı Yok</h6>
                    <p class="text-muted small">Abone sistemde yeni olduğu için veya henüz tahakkuk yapılmadığı için fatura bulunmuyor.</p>
                </div>
            </div>

            <!-- İş Emirleri Tab -->
            <div class="tab-pane fade" id="isemri" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Abonenin İş Emirleri (Açma/Kesme)</h5>
                    <button class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> İş Emri Oluştur</button>
                </div>
                <div class="text-center py-5 bg-white rounded-3 border border-dashed">
                    <i class="bi bi-tools text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="fw-bold text-secondary">İş Emri Bulunmuyor</h6>
                    <p class="text-muted small">Bu abone ile ilgili sahaya iletilmiş bir iş emri kaydı yok.</p>
                </div>
            </div>

            <!-- Bildirimler Tab -->
            <div class="tab-pane fade" id="bildirim" role="tabpanel">
                <h5 class="fw-bold mb-4">Gönderilen SMS / Mail Bildirimleri</h5>
                <div class="text-center py-5 bg-white rounded-3 border border-dashed">
                    <i class="bi bi-bell text-muted fs-1 mb-3 d-block"></i>
                    <h6 class="fw-bold text-secondary">Bildirim Geçmişi Boş</h6>
                    <p class="text-muted small">Aboneye henüz bir bilgilendirme mesajı gönderilmemiş.</p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // URL'de bir hash varsa (#sozlesme gibi) o sekmeyi aktif yap
            var hash = window.location.hash;
            if (hash) {
                var triggerEl = document.querySelector('button[data-bs-target="' + hash + '"]');
                if (triggerEl) {
                    var tab = new bootstrap.Tab(triggerEl);
                    tab.show();
                }
            }
        });
    </script>
}
