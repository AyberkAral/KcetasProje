@model KcetasWeb.ViewModels.AboneListeViewModel
@{
    ViewData["Title"] = "Aboneler (Müşteriler)";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="h4 text-primary fw-bold">
        <i class="bi bi-people-fill me-2"></i> Abone & Müşteri Yönetimi
    </h2>
    <a href="/Abone/Yeni" class="btn btn-primary fw-bold px-4 shadow-sm">
        <i class="bi bi-person-plus-fill me-2"></i> Yeni Abone Ekle
    </a>
</div>

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-@TempData["MesajTip"] alert-dismissible fade show shadow-sm" role="alert">
        @TempData["Mesaj"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Abone No</th>
                        <th>Ad Soyad / Ünvan</th>
                        <th>TCKN / VKN</th>
                        <th>Telefon</th>
                        <th>Mail</th>
                        <th>Tip</th>
                        <th>Durum</th>
                        <th class="pe-4 text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Aboneler)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@item.AboneNo</td>
                            <td class="fw-bold">@item.AdSoyad</td>
                            <td><span class="badge bg-light text-dark border font-monospace">@item.KimlikNoMaskeli</span></td>
                            <td>@item.Telefon</td>
                            <td>@item.Mail</td>
                            <td>
                                @if(item.AboneTipi == "Gerçek" || item.AboneTipi == "BIREYSEL") {
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info">@item.AboneTipi</span>
                                } else {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">@item.AboneTipi</span>
                                }
                            </td>
                            <td>
                                @if (item.Durum == "Aktif")
                                {
                                    <span class="badge bg-success">@item.Durum</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Durum</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border" type="button" data-bs-toggle="dropdown">
                                        İşlem <i class="bi bi-chevron-down ms-1"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item fw-semibold" href="/Abone/Detay/@item.AboneId"><i class="bi bi-eye text-primary me-2"></i> Detay</a></li>
                                        <li><a class="dropdown-item fw-semibold" href="/Abone/Detay/@item.AboneId#sozlesme"><i class="bi bi-journal-text text-info me-2"></i> Sözleşmeleri Gör</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item fw-semibold" href="/Abone/Duzenle/@item.AboneId"><i class="bi bi-pencil text-warning me-2"></i> Düzenle</a></li>
                                        <li>
                                            <form action="/Abone/Sil/@item.AboneId" method="post" onsubmit="return confirm('Bu aboneyi silmek istediğinize emin misiniz?');">
                                                <button type="submit" class="dropdown-item fw-semibold text-danger"><i class="bi bi-trash text-danger me-2"></i> Sil</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Aboneler.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">Sistemde kayıtlı abone bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
