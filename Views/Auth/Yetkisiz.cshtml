@{
    ViewData["Title"] = "Yetkisiz Erişim";
}

<section class="kc-surface kc-narrow-surface mx-auto">
    <div class="kc-surface-body text-center py-10">
        <div class="kc-stat-icon danger mx-auto mb-5">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 class="fw-bolder text-danger mb-3">Erişim Engellendi</h2>
        <p class="text-muted fw-semibold mb-6">
            Bu sayfa için gerekli rol izni hesabınızda bulunmuyor.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-door me-1"></i> Ana Sayfa
            </a>
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-light-danger">
                <i class="bi bi-box-arrow-right me-1"></i> Başka Hesapla Giriş
            </a>
        </div>
    </div>
</section>
