@using KcetasWeb.Models.entities
@using KcetasWeb.Services.Interfaces
@{
    ViewData["Title"] = "Gösterge Paneli";

    var toplamKullanici = ViewBag.ToplamKullanici ?? 0;
    var aktifKullanici = ViewBag.AktifKullanici ?? 0;
    var aktifTuketimNoktasi = ViewBag.AktifTuketimNoktasi ?? 0;
    var sonKullanicilar = ViewBag.SonKullanicilar as IEnumerable<Kullanici> ?? Enumerable.Empty<Kullanici>();
}

<section class="kc-dashboard-hero">
    <div>
        <span class="kc-hero-badge">
            <i class="bi bi-lightning-charge-fill"></i>
            Canlı operasyon özeti
        </span>
        <h2>KCETAŞ süreçlerini tek panelden yönetin.</h2>
        <p>Tüketim noktaları, kullanıcılar, saha işleri ve entegrasyon kuyruğu için en kritik durum bilgileri burada toplanır.</p>

        <div class="kc-hero-metrics">
            <div class="kc-hero-metric">
                <strong>@aktifTuketimNoktasi</strong>
                <span>Aktif tüketim noktası</span>
            </div>
            <div class="kc-hero-metric">
                <strong>@aktifKullanici</strong>
                <span>Aktif kullanıcı</span>
            </div>
        </div>
    </div>

    <div class="kc-hero-panel">
        <div>
            <img src="~/images/logo3.png" asp-append-version="true" alt="KCETAŞ" />
        </div>
        <div>
            <strong>Elektrik dağıtım operasyonları</strong>
            <span>Son güncelleme: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
    </div>
</section>

<section class="kc-stat-grid">
    <div class="kc-stat-card">
        <div class="kc-stat-icon">
            <i class="bi bi-people-fill"></i>
        </div>
        <div>
            <span>Toplam Kullanıcı</span>
            <strong>@toplamKullanici</strong>
        </div>
    </div>

    <div class="kc-stat-card">
        <div class="kc-stat-icon success">
            <i class="bi bi-person-check-fill"></i>
        </div>
        <div>
            <span>Aktif Kullanıcı</span>
            <strong>@aktifKullanici</strong>
        </div>
    </div>
</section>

<h3 class="mb-4 text-gray-800">Hızlı Erişim</h3>
<div class="row g-4 mb-5">
    <div class="col-xl-3 col-md-6">
        <a asp-controller="TuketimNoktasi" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-lightning-charge-fill fs-2x text-info me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Tüketim Noktaları</h5>
                    <span class="text-muted fs-7">Tüketim verileri</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Sozlesme" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-file-earmark-check-fill fs-2x text-primary me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Sözleşmeler</h5>
                    <span class="text-muted fs-7">Sözleşme listesi</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Abone" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-people-fill fs-2x text-success me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Abone Yönetimi</h5>
                    <span class="text-muted fs-7">Aboneleri yönetin</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="AboneSorgulama" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-search fs-2x text-primary me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Abone Sorgulama</h5>
                    <span class="text-muted fs-7">Detaylı arama</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="IsEmri" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-clipboard2-pulse-fill fs-2x text-warning me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">İş Emirleri</h5>
                    <span class="text-muted fs-7">Saha operasyonları</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="EndeksOkuma" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-speedometer2 fs-2x text-danger me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Endeks Okuma</h5>
                    <span class="text-muted fs-7">Okuma işlemleri</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Sayac" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-cpu-fill fs-2x text-secondary me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Sayaç İşlemleri</h5>
                    <span class="text-muted fs-7">Sayaç yönetimi</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Fatura" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-receipt-cutoff fs-2x text-success me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Faturalar</h5>
                    <span class="text-muted fs-7">Finans ve fatura</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Belgeler" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-folder2-open fs-2x text-warning me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Belgeler (Arşiv)</h5>
                    <span class="text-muted fs-7">Arşivlenen evraklar</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="Admin" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-shield-lock-fill fs-2x text-dark me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Admin Paneli</h5>
                    <span class="text-muted fs-7">Sistem yönetimi</span>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-3 col-md-6">
        <a asp-controller="AuditLog" asp-action="Index" class="card h-100 text-decoration-none shadow-sm border hover-elevate-up">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-clock-history fs-2x text-info me-3"></i>
                <div>
                    <h5 class="card-title fw-bold text-dark mb-1">Denetim İzleri</h5>
                    <span class="text-muted fs-7">Sistem geçmişi</span>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-12">
        <section class="kc-surface h-100">
            <div class="kc-surface-header">
                <h3>Son Kullanıcılar</h3>
                <a class="btn btn-sm btn-light-primary" asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-people me-1"></i> Kullanıcı yönetimi
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-row-dashed align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>Kayıt</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (sonKullanicilar.Any())
                    {
                        foreach (var kullanici in sonKullanicilar)
                        {
                            var rol = RolListesi.BulRolId(kullanici.rol_id ?? 0)?.aciklama ?? "Rol atanmadı";
                            var aktifMi = string.Equals(kullanici.durum, "AKTIF", StringComparison.OrdinalIgnoreCase) ||
                                          string.Equals(kullanici.durum, "Aktif", StringComparison.OrdinalIgnoreCase);
                            <tr>
                                <td class="fw-bold text-gray-800">@kullanici.ad_soyad</td>
                                <td>@kullanici.kullanici_adi</td>
                                <td class="text-muted">@rol</td>
                                <td>
                                    <span class="badge @(aktifMi ? "badge-light-success" : "badge-light-warning")">
                                        @(kullanici.durum ?? "Bilinmiyor")
                                    </span>
                                </td>
                                <td class="text-muted">@(kullanici.created_at?.ToString("dd.MM.yyyy") ?? "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-8">Henüz kullanıcı kaydı bulunamadı.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
