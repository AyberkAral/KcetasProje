@{
    ViewData["Title"] = "Yeni Endeks Okuma Girişi";
}

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">
        <div class="mb-3">
            <a href="/EndeksOkuma" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Listeye Dön
            </a>
        </div>
        
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary bg-opacity-10 border-0 py-3">
                <h5 class="mb-0 text-primary fw-bold">
                    <i class="bi bi-journal-text me-2"></i> Yeni Endeks Okuma Kaydı
                </h5>
            </div>
            
            <div class="card-body p-4">
                <form action="/EndeksOkuma/Yeni" method="post">
                    
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Tüketim Noktası (Abone) <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="TuketimNoktasiId" required>
                                <option value="">Tüketim Noktası Seçin...</option>
                                @if (ViewBag.TuketimNoktalari != null)
                                {
                                    foreach (var tn in (IEnumerable<KcetasWeb.Models.TuketimNoktasi>)ViewBag.TuketimNoktalari)
                                    {
                                        <option value="@tn.TuketimNoktasiId">@tn.tekil_kod - @tn.il_adi</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Sayaç Seri No <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="SayacId" required>
                                <option value="">Sayaç Seçin...</option>
                                @if (ViewBag.Sayaclar != null)
                                {
                                    foreach (var sayac in (IEnumerable<KcetasWeb.Models.Sayac>)ViewBag.Sayaclar)
                                    {
                                        <option value="@sayac.sayac_id">@sayac.seri_no (@sayac.marka)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Okuma Tipi <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="okuma_tipi">
                                <option value="Manuel">Manuel</option>
                                <option value="Otomatik">Otomatik</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Okuma Kaynağı <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="okuma_kaynagi">
                                <option value="T1 (Gündüz)">T1 (Gündüz)</option>
                                <option value="T2 (Puant)">T2 (Puant)</option>
                                <option value="T3 (Gece)">T3 (Gece)</option>
                                <option value="T (Toplam)">T (Toplam)</option>
                            </select>
                        </div>
                    </div>

                    <div class="alert alert-info border-0 rounded-3 mb-4 d-flex align-items-center">
                        <i class="bi bi-info-circle-fill fs-4 me-3 text-info"></i>
                        <div>Lütfen sayacın üzerindeki T1 (Gündüz), T2 (Puant), T3 (Gece) veya Toplam (T) değerlerini giriniz. MVP aşamasında sadece Aktif Endeks baz alınmaktadır.</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Önceki Endeks <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.001" name="onceki_endeks" class="form-control form-control-lg" required placeholder="0.000" />
                                <span class="input-group-text bg-white">kWh</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Güncel Endeks <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.001" name="yeni_endeks" class="form-control form-control-lg border-primary" required placeholder="0.000" />
                                <span class="input-group-text bg-primary text-white border-primary">kWh</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Not</label>
                        <textarea name="aciklama" class="form-control bg-light" rows="2" placeholder="Gerekliyse bir açıklama yazınız..."></textarea>
                    </div>

                    <hr class="text-muted my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/EndeksOkuma" class="btn btn-light border px-4 py-2">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check-lg me-1"></i> Kaydet ve Kapat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
