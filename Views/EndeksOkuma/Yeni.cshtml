@{
    ViewData["Title"] = "Yeni Endeks Okuma Girişi";
}

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">
        <div class="mb-3">
            <a href="/EndeksOkuma" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Listeye Dön
            </a>
        </div>
        
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary bg-opacity-10 border-0 py-3">
                <h5 class="mb-0 text-primary fw-bold">
                    <i class="bi bi-journal-text me-2"></i> Yeni Endeks Okuma Kaydı
                </h5>
            </div>
            
            <div class="card-body p-4">
                <form action="/EndeksOkuma/Yeni" method="post">
                    @if (TempData["WarningMessage"] != null)
                    {
                        <div class="alert alert-warning">@TempData["WarningMessage"]</div>
                    }

                    <div class="row mb-4">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Sözleşme Seçimi <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg border-primary" id="sozlesmeSelect" required>
                                <option value="">Önce Sözleşme Seçin...</option>
                                @if (ViewBag.Sozlesmeler != null && ViewBag.TuketimNoktalari != null)
                                {
                                    var sozlesmeler = (IEnumerable<KcetasWeb.Models.Sozlesme>)ViewBag.Sozlesmeler;
                                    var tnler = ((IEnumerable<KcetasWeb.Models.TuketimNoktasi>)ViewBag.TuketimNoktalari).GroupBy(x => x.tuketim_noktasi_id).ToDictionary(g => g.Key, g => g.First());
                                    var sayaclar = ViewBag.Sayaclar != null ? ((IEnumerable<KcetasWeb.Models.Sayac>)ViewBag.Sayaclar).Where(s => s.tuketim_noktasi_id != null).GroupBy(x => x.tuketim_noktasi_id).ToDictionary(g => g.Key, g => g.FirstOrDefault()?.sayac_id ?? 0) : new Dictionary<int?, int>();

                                    foreach (var sozlesme in sozlesmeler.Where(s => s.durum != KcetasWeb.Models.Enums.SozlesmeDurumu.Feshedildi && s.durum != KcetasWeb.Models.Enums.SozlesmeDurumu.Pasif))
                                    {
                                        if (tnler.TryGetValue(sozlesme.tuketim_noktasi_id, out var tn))
                                        {
                                            var sayacId = sayaclar.TryGetValue(tn.tuketim_noktasi_id, out var sId) ? sId : 0;
                                            <option value="@sozlesme.sozlesme_id" data-tn="@tn.tuketim_noktasi_id" data-sayac="@sayacId">
                                                Sözleşme No: @sozlesme.sozlesme_id - Tesisat: @tn.tekil_kod
                                            </option>
                                        }
                                    }
                                }
                            </select>
                            <small class="text-muted">Sözleşme seçildiğinde Tüketim Noktası ve Sayaç otomatik doldurulacaktır.</small>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Tüketim Noktası (Abone) <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg text-muted" name="TuketimNoktasiId" required style="pointer-events: none; background-color: #e9ecef;" tabindex="-1">
                                <option value="">Sözleşme seçildiğinde otomatik dolar...</option>
                                @if (ViewBag.TuketimNoktalari != null)
                                {
                                    foreach (var tn in (IEnumerable<KcetasWeb.Models.TuketimNoktasi>)ViewBag.TuketimNoktalari)
                                    {
                                        <option value="@tn.tuketim_noktasi_id">@tn.tekil_kod</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Sayaç Seri No <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg text-muted" name="SayacId" required style="pointer-events: none; background-color: #e9ecef;" tabindex="-1">
                                <option value="">Sözleşme seçildiğinde otomatik dolar...</option>
                                @if (ViewBag.Sayaclar != null)
                                {
                                    foreach (var sayac in (IEnumerable<KcetasWeb.Models.Sayac>)ViewBag.Sayaclar)
                                    {
                                        <option value="@sayac.sayac_id">@sayac.seri_no (@sayac.marka)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Okuma Tipi <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="okuma_tipi">
                                <option value="Rutin Okuma">Rutin Okuma</option>
                                <option value="Kontrol Okuması">Kontrol Okuması</option>
                                <option value="İş Emri Okuması">İş Emri Okuması</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Okuma Kaynağı <span class="text-danger">*</span></label>
                            <select class="form-select form-select-lg" name="okuma_kaynagi">
                                <option value="Manuel">Manuel</option>
                                <option value="Otomatik">Otomatik</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Önceki Endeks <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.001" name="onceki_endeks" id="onceki_endeks" class="form-control form-control-lg bg-light" required placeholder="0.000" readonly />
                                <span class="input-group-text bg-white">kWh</span>
                            </div>
                            <small class="text-muted" id="endeks_mesaj">Sayaç seçildiğinde otomatik doldurulur.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Güncel Endeks <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" step="0.001" name="yeni_endeks" class="form-control form-control-lg border-primary" required placeholder="0.000" />
                                <span class="input-group-text bg-primary text-white border-primary">kWh</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Not</label>
                        <textarea name="aciklama" class="form-control bg-light" rows="2" placeholder="Gerekliyse bir açıklama yazınız..."></textarea>
                    </div>

                    <hr class="text-muted my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/EndeksOkuma" class="btn btn-light border px-4 py-2">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check-lg me-1"></i> Kaydet ve Kapat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    
    <!-- jQuery is required for Select2 if not already included -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/tr.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize Select2
            $('#sozlesmeSelect').select2({
                theme: 'bootstrap-5',
                language: 'tr',
                placeholder: 'Önce Sözleşme Seçin veya Arayın...',
                width: '100%'
            });

            const sayacSelect = document.querySelector('select[name="SayacId"]');
            const oncekiEndeksInput = document.getElementById('onceki_endeks');
            const endeksMesaj = document.getElementById('endeks_mesaj');

            sayacSelect.addEventListener('change', function () {
                const sayacId = this.value;
                if (!sayacId) {
                    oncekiEndeksInput.value = '';
                    endeksMesaj.textContent = 'Sayaç seçildiğinde otomatik doldurulur.';
                    endeksMesaj.className = 'text-muted';
                    return;
                }

                endeksMesaj.textContent = 'Son endeks getiriliyor...';
                endeksMesaj.className = 'text-info';

                fetch(`/EndeksOkuma/GetSonEndeks?sayacId=${sayacId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.basarili) {
                            oncekiEndeksInput.value = data.endeks;
                            endeksMesaj.textContent = 'Sistemdeki son endeks otomatik getirildi.';
                            endeksMesaj.className = 'text-success';
                        } else {
                            oncekiEndeksInput.value = '0';
                            endeksMesaj.textContent = 'Bu sayaca ait eski okuma bulunamadı, 0 olarak başlatıldı.';
                            endeksMesaj.className = 'text-warning';
                        }
                    })
                    .catch(error => {
                        console.error('Hata:', error);
                        endeksMesaj.textContent = 'Endeks alınırken bir hata oluştu!';
                        endeksMesaj.className = 'text-danger';
                    });
            });

            // Akıllı Form Mantığı: Sözleşme değişince diğerlerini seç
            const tuketimNoktasiSelect = document.querySelector('select[name="TuketimNoktasiId"]');

            // Select2 change event triggers jQuery 'select2:select' or 'change'. 
            // We hook into jQuery change.
            $('#sozlesmeSelect').on('change', function () {
                const selectedOption = this.options[this.selectedIndex];
                const tnId = selectedOption.getAttribute('data-tn');
                const sayacId = selectedOption.getAttribute('data-sayac');

                if (tnId) {
                    tuketimNoktasiSelect.value = tnId;
                    
                    // Trigger flash effect
                    tuketimNoktasiSelect.classList.add('bg-warning', 'bg-opacity-25');
                    setTimeout(() => tuketimNoktasiSelect.classList.remove('bg-warning', 'bg-opacity-25'), 1000);
                }

                if (sayacId && sayacId != "0") {
                    sayacSelect.value = sayacId;
                    sayacSelect.classList.add('bg-warning', 'bg-opacity-25');
                    setTimeout(() => sayacSelect.classList.remove('bg-warning', 'bg-opacity-25'), 1000);
                    
                    // Manually trigger change event to fetch previous index
                    sayacSelect.dispatchEvent(new Event('change'));
                } else {
                    sayacSelect.value = '';
                    sayacSelect.dispatchEvent(new Event('change'));
                }
            });
        });
    </script>
}
