@model KcetasWeb.Models.Fatura

@{
    ViewData["Title"] = "Yeni Fatura Oluştur";
}

<div class="mb-4 mt-3">
    <h2 class="h4 text-primary fw-bold">Yeni Fatura Oluştur</h2>
    <p class="text-muted">Manuel olarak yeni bir fatura kaydı oluşturun.</p>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4">
        <form asp-action="Olustur" method="post">
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Abone Tipi</label>
                    <select asp-for="AboneTipi" class="form-select" required>
                        <option value="">Seçiniz...</option>
                        <option value="Mesken">Mesken</option>
                        <option value="Ticarethane">Ticarethane</option>
                        <option value="Sanayi">Sanayi</option>
                        <option value="Tarımsal Sulama">Tarımsal Sulama</option>
                    </select>
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold">Dönem</label>
                    <input asp-for="Donem" class="form-control" placeholder="Örn: 2026-06" required />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tüketim (kWh)</label>
                    <div class="input-group">
                        <input asp-for="TuketimKwh" type="number" step="0.01" class="form-control" required />
                        <span class="input-group-text">kWh</span>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Toplam Tutar</label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input asp-for="ToplamTutar" type="number" step="0.01" class="form-control" required />
                    </div>
                </div>
            </div>
            
            <hr class="text-muted mb-4" />
            
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light border fw-bold text-secondary">İptal</a>
                <button type="submit" class="btn btn-primary fw-bold px-4">Fatura Oluştur</button>
            </div>
        </form>
    </div>
</div>
