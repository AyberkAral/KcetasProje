@model KcetasWeb.Models.Sayac
@{
    ViewData["Title"] = "Sayaç Bağla";
    var tuketimNoktalari = ViewBag.TuketimNoktalari as List<KcetasWeb.Models.TuketimNoktasi>;
}

<div class="mb-4">
    <h2 class="text-primary fw-bold">Sayaç Bağlantı İşlemi</h2>
    <p class="text-muted"><strong>@Model.SayacNo</strong> numaralı sayacın bağlantı durumunu yönetin.</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form asp-action="Bagla" method="post">
            <input type="hidden" name="SayacId" value="@Model.SayacId" />
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Sayaç Marka/Model ID</label>
                    <input type="text" class="form-control" value="Marka: @Model.MarkaId / Model: @Model.ModelId" readonly>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tip</label>
                    <input type="text" class="form-control" value="@Model.Tip" readonly>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Tüketim Noktası (Bağlanacak Yer)</label>
                <select class="form-select" name="TuketimNoktasiId">
                    <option value="0">-- Boşa Al (Depoya Kaldır) --</option>
                    @if (tuketimNoktalari != null)
                    {
                        foreach (var nokta in tuketimNoktalari)
                        {
                            if (nokta.TuketimNoktasiId == Model.TuketimNoktasiId)
                            {
                                <option value="@nokta.TuketimNoktasiId" selected>@nokta.TuketimNoktasiNo (Mevcut)</option>
                            }
                            else
                            {
                                <option value="@nokta.TuketimNoktasiId">@nokta.TuketimNoktasiNo</option>
                            }
                        }
                    }
                </select>
                <div class="form-text">Boşa al seçeneği ile sayacı tüketim noktasından söküp depoya kaldırabilirsiniz.</div>
            </div>

            <div class="text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> İşlemi Kaydet</button>
            </div>
        </form>
    </div>
</div>