@model KcetasWeb.Models.Sayac

@{
    ViewData["Title"] = "Sayaç Detayı";
    var tuketimNoktalari = ViewBag.TuketimNoktalari as List<KcetasWeb.Models.TuketimNoktasi>;
    var bagliNokta = tuketimNoktalari?.FirstOrDefault(t => t.TuketimNoktasiId == Model.tuketim_noktasi_id);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-primary fw-bold">
            <i class="bi bi-speedometer2 me-2"></i> Sayaç Detayı
        </h2>
        <div>
            <a href="/Sayac/Index" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i> Listeye Dön
            </a>
            @if(Model.durum == "Depoda")
            {
                <a href="/Sayac/Bagla/@Model.sayac_id" class="btn btn-success shadow-sm">
                    <i class="bi bi-link-45deg"></i> Noktaya Bağla
                </a>
            }
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white p-4">
            <div class="d-flex align-items-center">
                <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 60px; height: 60px; font-size: 24px;">
                    <i class="bi bi-speedometer"></i>
                </div>
                <div class="ms-3">
                    <h3 class="mb-0 fw-bold">Seri No: @Model.seri_no</h3>
                    <p class="mb-0 opacity-75">ID: @Model.sayac_id | Kayıt: @Model.CreatedAt.ToString("dd.MM.yyyy")</p>
                </div>
                <div class="ms-auto text-end">
                    @if (Model.durum == "Bağlı")
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-link-45deg me-1"></i> Sahada Bağlı</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fs-6 shadow-sm"><i class="bi bi-box me-1"></i> Depoda Bekliyor</span>
                    }
                </div>
            </div>
        </div>

        <div class="card-body p-4 bg-light">
            <div class="row g-4 mb-2">
                <div class="col-md-6">
                    <h6 class="text-muted fw-bold mb-3"><i class="bi bi-info-circle me-1"></i> Cihaz Teknik Bilgileri</h6>
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light h-100">
                        <table class="table table-borderless table-sm mb-0">
                            <tbody>
                                <tr>
                                    <td class="text-muted fw-bold w-50">Marka</td>
                                    <td class="text-dark fw-medium">@Model.marka</td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-bold">Model</td>
                                    <td class="text-dark fw-medium">@Model.model</td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-bold">Faz Tipi</td>
                                    <td class="text-dark fw-medium">
                                        <span class="badge bg-secondary">@Model.faz</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-bold">Çarpan Değeri</td>
                                    <td class="text-dark fw-medium">@Model.carpan.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted fw-bold">Sistem Durumu</td>
                                    <td class="text-dark fw-medium">@Model.status</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted fw-bold mb-3"><i class="bi bi-geo-alt me-1"></i> Bağlantı & Saha Durumu</h6>
                    <div class="p-3 bg-white rounded-3 shadow-sm border border-light h-100">
                        @if (Model.tuketim_noktasi_id > 0 && bagliNokta != null)
                        {
                            <div class="mb-3">
                                <label class="text-muted small fw-bold mb-1 text-uppercase text-primary"><i class="bi bi-house-door-fill me-1"></i> Bağlı Olduğu Tüketim Noktası</label>
                                <p class="fs-6 fw-bold text-dark mb-0">@bagliNokta.tekil_kod - @bagliNokta.musteri_ad @bagliNokta.musteri_soyad</p>
                                <p class="text-muted small mt-1 mb-0">@bagliNokta.acik_adres</p>
                            </div>
                            <div class="mb-0 border-top pt-3">
                                <label class="text-muted small fw-bold mb-1 text-uppercase text-danger"><i class="bi bi-shield-lock-fill me-1"></i> Mühür Numarası</label>
                                <p class="fs-5 fw-bold text-danger mb-0 font-monospace">@Model.muhur_no</p>
                            </div>
                        }
                        else
                        {
                            <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center p-3 opacity-50">
                                <i class="bi bi-plug display-4 text-muted mb-2"></i>
                                <h6 class="fw-bold mb-1">Bağlantı Yok</h6>
                                <p class="small text-muted mb-0">Bu sayaç şu anda depoda bekliyor ve herhangi bir noktaya atanmamış.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top text-center text-muted small">
                Bu sayaç sisteme en son @(Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")) tarihinde güncellenmiştir.
            </div>
        </div>
    </div>
</div>
