@model IEnumerable<KcetasWeb.Models.Sayac>

@{
    ViewData["Title"] = "Sayaç Envanteri";
    var tuketimNoktalari = ViewBag.TuketimNoktalari as List<KcetasWeb.Models.TuketimNoktasi>;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="h4 text-primary fw-bold">Sayaç Envanteri ve Durumları</h2>
    <a href="/Sayac/Yeni" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Yeni Sayaç Ekle
    </a>
</div>

@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Seri No</th>
                        <th>Marka / Model</th>
                        <th>Faz Bilgisi</th>
                        <th>Çarpan</th>
                        <th>Mühür No</th>
                        <th>Durum</th>
                        <th>Bağlı Olduğu Nokta</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var tn = tuketimNoktalari?.FirstOrDefault(t => t.tuketim_noktasi_id == item.tuketim_noktasi_id);

                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.seri_no</td>
                                <td>@item.marka / @item.model</td>
                                <td>
                                    <span class="badge bg-secondary">@item.faz</span>
                                </td>
                                <td>@item.carpan</td>

                                <td>@item.muhur_no</td>

                                <td>
                                    @{
                                        string gorunenDurum = (item.durum == "TAKILI" || item.durum == "Bağlı" || item.tuketim_noktasi_id > 0) ? "Bağlı" : "Depoda";
                                        string bgClass = gorunenDurum == "Bağlı" ? "success" : "warning text-dark";
                                    }
                                    <span class="badge bg-@bgClass">
                                        @gorunenDurum
                                    </span>
                                </td>

                                <td>
                                    @if (tn != null)
                                    {
                                        <span class="fw-bold text-primary">@tn.tekil_kod</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Yok (Depoda)</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border" type="button" data-bs-toggle="dropdown">
                                            İşlem <i class="bi bi-chevron-down ms-1"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li>
                                                <a href="/Sayac/Detay/@item.sayac_id" class="dropdown-item fw-semibold">
                                                    <i class="bi bi-info-circle text-info me-2"></i> Detay
                                                </a>
                                            </li>
                                            <li>
                                                <a href="/Sayac/Bagla/@item.sayac_id" class="dropdown-item fw-semibold">
                                                    <i class="bi bi-link-45deg text-primary me-2"></i> @(item.durum == "Bağlı" ? "Sök / Değiştir" : "Bağla")
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                Kayıtlı sayaç bulunmamaktadır.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>