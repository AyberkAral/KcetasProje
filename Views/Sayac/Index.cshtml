@model IEnumerable<KcetasWeb.Models.Sayac>
@{
    ViewData["Title"] = "Sayaç Listesi ve Bağlama";
    var tuketimNoktalari = ViewBag.TuketimNoktalari as List<KcetasWeb.Models.TuketimNoktasi>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">Sayaç Listesi</h2>
</div>

@if (TempData["BasariMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["BasariMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Sayaç No</th>
                        <th>Marka / Model ID</th>
                        <th>Tip</th>
                        <th>Durum</th>
                        <th>Bağlı Tüketim Noktası</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var bagliNokta = tuketimNoktalari?.FirstOrDefault(t => t.TuketimNoktasiId == item.TuketimNoktasiId);
                        <tr>
                            <td class="fw-bold">@item.SayacNo</td>
                            <td>Marka: @item.MarkaId / Model: @item.ModelId</td>
                            <td>@item.Tip</td>
                            <td>
                                @if (item.Durum == "Bağlı")
                                {
                                    <span class="badge bg-success">Bağlı</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Depoda</span>
                                }
                            </td>
                            <td>
                                @if (bagliNokta != null)
                                {
                                    <span>@bagliNokta.tekil_kod</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Bagla" asp-route-id="@item.SayacId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-link"></i> Bağla / Yönet
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                Sistemde kayıtlı sayaç bulunmamaktadır.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
