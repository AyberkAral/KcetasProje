@model KcetasWeb.Models.Sayac

@{
    ViewData["Title"] = "Yeni Sayaç Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 text-primary fw-bold">
                    <i class="bi bi-plus-circle me-2"></i> Yeni Sayaç Ekle
                </h2>
                <a href="/Sayac/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Listeye Dön
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <form asp-action="Yeni" method="post">
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="seri_no" class="form-label fw-bold text-muted">Seri Numarası <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-upc-scan text-primary"></i></span>
                                    <input asp-for="seri_no" class="form-control border-start-0 ps-0" placeholder="Örn: S-1004" required />
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="marka" class="form-label fw-bold text-muted">Marka <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-tag-fill text-primary"></i></span>
                                    <input asp-for="marka" class="form-control border-start-0 ps-0" placeholder="Örn: Makel, Luna" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="model" class="form-label fw-bold text-muted">Model <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-cpu-fill text-primary"></i></span>
                                    <input asp-for="model" class="form-control border-start-0 ps-0" placeholder="Örn: M500" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="faz" class="form-label fw-bold text-muted">Faz Tipi <span class="text-danger">*</span></label>
                                <select asp-for="faz" class="form-select" required>
                                    <option value="Monofaze">Monofaze</option>
                                    <option value="Trifaze">Trifaze</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="carpan" class="form-label fw-bold text-muted">Çarpan Değeri <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-x-circle-fill text-primary"></i></span>
                                    <input asp-for="carpan" type="number" step="0.01" class="form-control border-start-0 ps-0" placeholder="1.00" required />
                                </div>
                                <div class="form-text">Genellikle direkt sayaçlar için 1, akım trafolu sayaçlar için trafo oranıdır.</div>
                            </div>
                        </div>

                        <hr class="my-4 text-muted">
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="bi bi-save me-2"></i> Sisteme Ekle
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
