@using System.Security.Claims
@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "KCETAŞ Portal";
}

<!DOCTYPE html>
<html lang="tr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - KCETAŞ Portal</title>
    <link rel="shortcut icon" href="~/assets/media/logos/favicon.ico" />
    <link href="~/assets/plugins/global/plugins.bundle.css" rel="stylesheet" type="text/css" asp-append-version="true" />
    <link href="~/assets/css/style.bundle.css" rel="stylesheet" type="text/css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="kc-app-body">
    <script>
        if(localStorage.getItem("sidebar-collapsed") === "true") {
            document.body.classList.add("sidebar-collapsed");
        }
    </script>
@if (User.Identity?.IsAuthenticated == true)
{
    var displayName = User.Identity?.Name ?? "Kullanıcı";
    var roleName = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Personel";
    var initial = string.IsNullOrWhiteSpace(displayName) ? "K" : displayName.Trim().Substring(0, 1).ToUpperInvariant();

    <div class="kc-app-shell">
        <aside class="kc-sidebar offcanvas-lg offcanvas-start" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
            <div class="kc-sidebar-header">
                <a class="kc-brand" asp-controller="Home" asp-action="Index" id="sidebarOffcanvasLabel">
                    <img src="~/images/logo3.png" asp-append-version="true" alt="KCETAŞ" />
                    <span>
                        <strong>KCETAŞ</strong>
                        <small>Bilgi Portalı</small>
                    </span>
                </a>
                <button type="button" class="btn btn-icon btn-sm btn-light d-lg-none" data-bs-dismiss="offcanvas" aria-label="Menüyü kapat">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="kc-sidebar-body offcanvas-body">
                <partial name="_SidebarMenu" />
            </div>
        </aside>

        <div class="kc-app-main">
            <header class="kc-topbar">
                <div class="d-flex align-items-center gap-3 min-w-0">
                    <button class="btn btn-icon btn-light d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas" aria-label="Menüyü aç">
                        <i class="bi bi-list fs-2"></i>
                    </button>
                    <button class="btn btn-icon btn-light d-none d-lg-inline-flex" type="button" id="desktopSidebarToggle" aria-label="Menüyü aç/kapat">
                        <i class="bi bi-list fs-2"></i>
                    </button>
                    <div class="min-w-0">
                        <span class="kc-eyebrow">KCETAŞ Operasyon</span>
                        <h1 class="kc-page-title">@pageTitle</h1>
                    </div>
                </div>

                <div class="kc-user-area">
                    <div class="kc-user-avatar">@initial</div>
                    <div class="kc-user-copy d-none d-sm-block">
                        <strong>@displayName</strong>
                        <span>@roleName</span>
                    </div>
                    <a class="btn btn-sm btn-light-primary" asp-controller="Profil" asp-action="Index">
                        <i class="bi bi-person-fill me-1"></i> Profil
                    </a>
                    <a class="btn btn-sm btn-light-danger" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Çıkış
                    </a>
                </div>
            </header>

            <main class="kc-content">
                @RenderBody()
            </main>

            <footer class="kc-footer">
                <span>&copy; @DateTime.Now.Year KCETAŞ</span>
                <span>Elektrik dağıtım yönetim portalı</span>
            </footer>
        </div>
    </div>
}
else
{
    <div class="kc-public-shell">
        <header class="kc-public-nav">
            <a class="kc-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo3.png" asp-append-version="true" alt="KCETAŞ" />
                <span>
                    <strong>KCETAŞ</strong>
                    <small>Bilgi Portalı</small>
                </span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <a class="btn btn-light btn-sm" asp-controller="Auth" asp-action="Register">Hesap Aç</a>
                <a class="btn btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
            </div>
        </header>

        <main class="kc-public-content">
            @RenderBody()
        </main>

        <footer class="kc-footer kc-footer-public">
            <span>&copy; @DateTime.Now.Year KCETAŞ</span>
            <span>Elektrik dağıtım yönetim portalı</span>
        </footer>
    </div>
}

    <script src="~/assets/plugins/global/plugins.bundle.js" asp-append-version="true"></script>
    <script src="~/assets/js/scripts.bundle.js" asp-append-version="true"></script>
    <script src="~/assets/js/widgets.bundle.js" asp-append-version="true"></script>
    <script src="~/js/validations.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var toggleBtn = document.getElementById("desktopSidebarToggle");
            if(toggleBtn) {
                toggleBtn.addEventListener("click", function () {
                    document.body.classList.toggle("sidebar-collapsed");
                    var isCollapsed = document.body.classList.contains("sidebar-collapsed");
                    localStorage.setItem("sidebar-collapsed", isCollapsed);
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
