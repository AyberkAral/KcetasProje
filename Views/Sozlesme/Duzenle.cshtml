@model KcetasWeb.Models.Sozlesme

@{
    ViewData["Title"] = "Sözleşme Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="mb-3">
            <a href="/Sozlesme/Detay/@Model.sozlesme_no" class="btn btn-sm btn-outline-secondary">&larr; Detaya Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h5 class="card-title mb-0 fw-bold">Sözleşme Düzenle: @Model.sozlesme_no</h5>
            </div>
            <div class="card-body p-4">
                <form action="/Sozlesme/Duzenle" method="post">
                    <input type="hidden" name="sozlesme_no" value="@Model.sozlesme_no" />

                    <h6 class="fw-bold text-warning border-bottom pb-2 mb-3 mt-2">1. Sözleşme ve Tesisat Bilgileri</h6>
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketim Noktası ID <span class="text-muted small">(Sabit)</span></label>
                            <input type="number" class="form-control bg-light" name="tuketim_noktasi_id" value="@Model.tuketim_noktasi_id" readonly />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sözleşme Tipi <span class="text-danger">*</span></label>
                            <select class="form-select" name="sozlesme_tipi" required>
                                <option value="Perakende Satış" selected="@(Model.sozlesme_tipi == "Perakende Satış")">Perakende Satış Sözleşmesi</option>
                                <option value="İkili Anlaşma" selected="@(Model.sozlesme_tipi == "İkili Anlaşma")">İkili Anlaşma (Serbest Tüketici)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tarife Grubu <span class="text-danger">*</span></label>
                            <select class="form-select" name="tarife_grubu" required>
                                <option value="Mesken" selected="@(Model.tarife_grubu == "Mesken")">Mesken</option>
                                <option value="Ticarethane" selected="@(Model.tarife_grubu == "Ticarethane")">Ticarethane</option>
                                <option value="Sanayi" selected="@(Model.tarife_grubu == "Sanayi")">Sanayi</option>
                                <option value="Tarımsal Sulama" selected="@(Model.tarife_grubu == "Tarımsal Sulama")">Tarımsal Sulama</option>
                                <option value="Aydınlatma" selected="@(Model.tarife_grubu == "Aydınlatma")">Aydınlatma</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sayaç <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="sayac" value="@Model.sayac" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Başlangıç Endeksi <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control" name="baslangic_endeksi" value="@Model.baslangic_endeksi.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Güvence Bedeli (TL)</label>
                            <input type="number" step="0.01" class="form-control" name="guvence_bedeli" value="@Model.guvence_bedeli.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Ödeme Şekli <span class="text-danger">*</span></label>
                            <select class="form-select" name="odeme_sekli" required>
                                <option value="Nakit" selected="@(Model.odeme_sekli == "Nakit")">Nakit</option>
                                <option value="Kredi Kartı" selected="@(Model.odeme_sekli == "Kredi Kartı")">Kredi Kartı</option>
                                <option value="Havale/EFT" selected="@(Model.odeme_sekli == "Havale/EFT")">Havale/EFT</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Durum</label>
                            <select class="form-select" name="statu">
                                <option value="Aktif" selected="@(Model.statu == "Aktif")">Aktif</option>
                                <option value="Güvence Bekliyor" selected="@(Model.statu == "Güvence Bekliyor")">Güvence Bekliyor</option>
                                <option value="Feshedildi" selected="@(Model.statu == "Feshedildi")">Feshedildi</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="fw-bold text-warning border-bottom pb-2 mb-3 mt-4">2. Abone (Müşteri) Bilgileri</h6>
                    <div class="row mb-3">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Ad</label>
                            <input type="text" class="form-control" name="ad" value="@Model.ad" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Soyad</label>
                            <input type="text" class="form-control" name="soyad" value="@Model.soyad" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Ünvan (Tüzel Kişi)</label>
                            <input type="text" class="form-control" name="unvan" value="@Model.unvan" />
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">TC Kimlik No (Gerçek Kişi)</label>
                            <input type="text" class="form-control" name="tckn" value="@Model.tckn" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Vergi No (Tüzel Kişi)</label>
                            <input type="text" class="form-control" name="vkn" value="@Model.vkn" />
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Telefon</label>
                            <input type="text" class="form-control" name="telefon" value="@Model.telefon" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">E-Posta</label>
                            <input type="email" class="form-control" name="e_posta" value="@Model.e_posta" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">İletişim Tercihi</label>
                            <select class="form-select" name="iletisim_tercihi">
                                <option value="SMS" selected="@(Model.iletisim_tercihi == "SMS")">SMS</option>
                                <option value="Email" selected="@(Model.iletisim_tercihi == "Email")">E-Posta</option>
                            </select>
                        </div>
                    </div>

                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Sozlesme/Detay/@Model.sozlesme_no" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
