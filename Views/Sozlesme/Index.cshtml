@model IEnumerable<KcetasWeb.ViewModels.SozlesmeViewModels>

@{
    ViewData["Title"] = "Sözleşmeler";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="h4 text-primary fw-bold">Sözleşmeler Listesi</h2>
    <a href="/Sozlesme/Yeni" class="btn btn-primary fw-bold">+ Yeni Sözleşme</a>
</div>

@if (TempData["SozlesmeMesaji"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        @TempData["SozlesmeMesaji"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sözleşme No</th>
                        <th>Müşteri Ad Soyad / Ünvan</th>
                        <th>Tekil Kod</th>
                        <th>Tüketim Noktası ID</th>
                        <th>Sözleşme Tipi</th>
                        <th>Tarife</th>
                        <th>Güvence Bedeli</th>
                        <th>Başlangıç / Bitiş Tarihi</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var tcMaskeli = !string.IsNullOrEmpty(item.tckn) && item.tckn.Length >= 4 ? "***" + item.tckn.Substring(item.tckn.Length - 4) : item.tckn;
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.sozlesme_no</td>
                                <td>@(item.ad) @(item.soyad) @(item.unvan)</td>
                                <td>
                                    <span class="badge bg-secondary">@item.tekil_kod</span>
                                    
                                </td>
                                <td>@item.tuketim_noktasi_id</td>
                                <td>@item.sozlesme_tipi</td>
                                <td>@item.tarife_grubu</td>
                                <td class="fw-bold">@item.guvence_bedeli.ToString("C")</td>
                                <td>@item.baslangic_tarihi / @item.bitis_tarihi</td>
                                <td>
                                    <span class="badge bg-@(item.statu == "Aktif" ? "success" : (item.statu == "Güvence Bekliyor" ? "warning text-dark" : "danger"))">
                                        @item.statu
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Sozlesme/Detay/@item.sozlesme_no" class="btn btn-sm btn-outline-primary rounded-3 px-3">Detay</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Kayıtlı sözleşme bulunmamaktadır.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
