@{
    ViewData["Title"] = "Yeni Sözleşme";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="mb-3">
            <a href="/Sozlesme" class="btn btn-sm btn-outline-secondary">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="card-title mb-0 fw-bold">Yeni Perakende Satış Sözleşmesi Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form action="/Sozlesme/Yeni" method="post">
                    
                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3 mt-2">1. Sözleşme ve Tesisat Bilgileri</h6>
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketim Noktası (Tesisat) <span class="text-danger">*</span></label>
                            <select class="form-select select2" name="tuketim_noktasi_id" required>
                                <option value="" disabled selected>Tesisat Seçiniz...</option>
                                @if(ViewBag.TuketimNoktalari != null)
                                {
                                    foreach (var tn in ViewBag.TuketimNoktalari)
                                    {
                                        <option value="@tn.tuketim_noktasi_id">@tn.tekil_kod - @tn.mahalle @tn.bina_no</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Abone (Müşteri) <span class="text-danger">*</span></label>
                            <select class="form-select select2" name="abone_id" required>
                                <option value="" disabled selected>Müşteri Seçiniz...</option>
                                @if(ViewBag.Aboneler != null)
                                {
                                    foreach (var abone in ViewBag.Aboneler)
                                    {
                                        <option value="@abone.abone_id">@(abone.tckn ?? abone.vkn) - @abone.Ad @abone.Soyad @abone.Unvan</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Sözleşme Tipi <span class="text-danger">*</span></label>
                            <select class="form-select" name="sozlesme_tipi" required>
                                <option value="Perakende Satış">BİREYSEL</option>
                                <option value="İkili Anlaşma">KURUMSAL</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tarife Grubu <span class="text-danger">*</span></label>
                            <select class="form-select" name="tarife_id" required>
                                <option value="" disabled selected>Seçiniz</option>
                                <option value="1">1 - Mesken</option>
                                <option value="3">3 - Ticarethane</option>
                                <option value="2">2 - Sanayi</option>
                                <option value="4">4 - Tarımsal Sulama</option>
                                <option value="5">5 - Aydınlatma</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Güvence Bedeli (TL)</label>
                            <input type="number" step="0.01" class="form-control" name="guvence_bedeli" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Ödeme Şekli <span class="text-danger">*</span></label>
                            <select class="form-select" name="odeme_sekli" required>
                                <option value="Nakit">Nakit</option>
                                <option value="Kredi Kartı">Kredi Kartı</option>
                                <option value="Havale/EFT">Havale/EFT</option>
                            </select>
                        </div>
                    </div>



                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/Sozlesme" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Sözleşmeyi Oluştur</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>