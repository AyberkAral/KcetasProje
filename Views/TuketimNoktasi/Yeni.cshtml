@model KcetasWeb.Models.TuketimNoktasi

@{
    ViewData["Title"] = "Yeni Tüketici ve Tüketim Noktası";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="mb-3">
            <a href="/TuketimNoktasi" class="btn btn-sm btn-outline-secondary">&larr; Listeye Geri Dön</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h5 class="card-title mb-0 fw-bold">Yeni Tüketici ve Tesisat Bilgisi Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form action="/TuketimNoktasi/Yeni" method="post">
                    


                    <!-- Tesisat Bilgileri -->
                    <h5 class="text-success border-bottom pb-2 mb-3 mt-4"><i class="bi bi-house-door"></i> Tesisat ve Adres Bilgileri</h5>
                    <div class="row mb-3">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold text-secondary">Tüketici Tekil Kodu</label>
                            <input type="text" class="form-control bg-light text-muted" placeholder="Sistem Tarafından Otomatik Atanacaktır" readonly />
                            <small class="text-muted">Kayıt tamamlandığında eşsiz bir tekil kod otomatik olarak üretilecektir.</small>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">İl Seçiniz <span class="text-danger">*</span></label>
                            <select class="form-select bg-light" name="il_adi" id="ilSelect" required readonly>
                                <option value="Kayseri" selected>Kayseri</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">İlçe Seçiniz <span class="text-danger">*</span></label>
                            <select class="form-select" name="ilce_id" id="ilceSelect" required>
                                <option value="">Önce İl Seçin</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label fw-bold">Bina No</label>
                            <input type="text" class="form-control" name="bina_no" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label fw-bold">Daire No</label>
                            <input type="text" class="form-control" name="bagimsiz_bolum_no" />
                        </div>
                        
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Açık Adres</label>
                            <textarea class="form-control" name="acik_adres" rows="2"></textarea>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tüketici Grubu <span class="text-danger">*</span></label>
                            <select class="form-select" name="tuketici_grubu" required>
                                <option value="MESKEN">MESKEN</option>
                                <option value="TİCARETHANE">TİCARETHANE</option>
                                <option value="SANAYİ">SANAYİ</option>
                                <option value="TARIMSAL SULAMA">TARIMSAL SULAMA</option>
                                <option value="AYDINLATMA">AYDINLATMA</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bağlantı Gücü (kW)</label>
                            <input type="number" step="0.01" class="form-control" name="baglanti_gucu_kw" />
                        </div>
                    </div>

                    <hr class="text-muted mb-4">

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/TuketimNoktasi" class="btn btn-light border">İptal</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">Noktayı Oluştur</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const kayseriIlceler = {
            "1": "Melikgazi", "2": "Kocasinan", "3": "Talas", "4": "Akkışla", 
            "5": "Bünyan", "6": "Develi", "7": "Felahiye", "8": "Hacılar",
            "9": "İncesu", "10": "Özvatan", "11": "Pınarbaşı", "12": "Sarıoğlan",
            "13": "Sarız", "14": "Tomarza", "15": "Yahyalı", "16": "Yeşilhisar"
        };



        document.addEventListener("DOMContentLoaded", function() {
            ilceDoldur();
        });

        function ilceDoldur() {
            var ilceSelect = document.getElementById("ilceSelect");
            
            ilceSelect.innerHTML = '<option value="">İlçe Seçin</option>';

            Object.keys(kayseriIlceler).forEach(function(id) {
                var option = document.createElement("option");
                option.value = id;
                option.text = id + " - " + kayseriIlceler[id];
                ilceSelect.appendChild(option);
            });
        }
    </script>
}